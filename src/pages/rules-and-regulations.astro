---
import Layout from '../layouts/Layout.astro';

const sections = [
	{
		title: "Town Houses & Cottages",
		icon: "home",
		rules: [
			"Charcoal grills/smokers or other open flames are not permitted on any property in Barrier Dunes.",
			"Please do not hang towels or clothing from decks or outside railings.",
			"Loud music is not permitted outside."
		]
	},
	{
		title: "General Information",
		icon: "info",
		rules: [
			"Fires and fireworks are not permitted anywhere on Barrier Dunes property.",
			"Golf carts are to be used for transportation purposes only and all drivers must be licensed and at least 16 years old. No parking on grass.",
			"Speed limit within the gates of Barrier Dunes is 17 miles per hour. For the safety of pedestrians and cyclists, please abide by the speed limit.",
			"The gate code changes monthly. Please make sure you and your guests have the proper monthly code.",
			"Sea turtle nesting season is May 1st through October 31st. Please turn off or shield outdoor lights and close drapes/blinds to prevent lights from shining onto the beach."
		]
	},
	{
		title: "Garbage & Maintenance",
		icon: "trash",
		rules: [
			"Normal collection (March 15 – Labor Day): Mon, Wed, Fri. Other times: Mon, Thu.",
			"Garbage must be placed in containment areas the night before pickup.",
			"Household garbage must be in bags and placed in closed garbage closets.",
			"Fish remnants (fish guts, bait, scallop shells) must be disposed of off-site.",
			"Large items (TVs, furniture, grills) will not be picked up and must be disposed of by homeowners."
		]
	},
	{
		title: "Parking & Vehicles",
		icon: "truck",
		rules: [
			"Only private passenger vehicles allowed in driveways.",
			"Boats and trailers must be parked under the unit (if they fit).",
			"Overflow parking is limited to 14 days while the owner/guest is on property.",
			"No parking on streets or grass. No R.V.'s or Campers allowed in common areas.",
			"Unauthorized vehicles are subject to towing at the owner's expense."
		]
	},
	{
		title: "Common Grounds & Pets",
		icon: "heart",
		rules: [
			"All pets must be kept on a leash at all times. Do not leave pets unattended on decks.",
			"Pet waste must be cleaned up immediately. Use the provided waste stations.",
			"Golf carts, skateboards, and scooters are not allowed on boardwalks or walkways."
		]
	},
	{
		title: "Pool Rules",
		icon: "droplet",
		rules: [
			"No lifeguard on duty – swim at your own risk.",
			"Pools are open from 9:00 A.M. until dusk.",
			"Children under 12 must be accompanied by an adult.",
			"No pets, glass containers, jumping, or diving allowed in pool areas.",
			"Do not remove pool furniture from the area."
		]
	},
	{
		title: "Tennis Court Rules",
		icon: "target",
		rules: [
			"Open from 8:00 A.M. until 10:00 P.M. Lights must be turned off when leaving.",
			"Regulation shoes must be worn. No bicycles, skateboards, or pets on courts.",
			"Courts are for tennis and pickle-ball only.",
			"Remove all trash (balls, cans, lids) before leaving."
		]
	},
	{
		title: "Beach Information",
		icon: "sun",
		rules: [
			"Walking or playing on the dunes is strictly prohibited by state law.",
			"Pets must be on a leash and waste disposed of properly (County Ordinance).",
			"Fill in all holes dug in the sand before dusk.",
			"All beach gear must be removed daily (Leave No Trace ordinance).",
			"Open fires must follow Gulf County ordinances (100ft from structures, natural wood only)."
		]
	}
];
---

<Layout title="Rules & Regulations">
	<section class="py-20 bg-beach-sand/10">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<span class="text-beach-sand font-sans text-[10px] uppercase tracking-[.3em] mb-4 block">COMMUNITY GUIDELINES</span>
			<h1 class="text-5xl font-serif text-beach-slate mb-8">Rules & Regulations</h1>
			<p class="text-beach-slate/70 font-sans text-sm leading-relaxed tracking-wide">
				Barrier Dunes is a community designed for peace and preservation. 
				Please abide by these regulations to ensure a safe and enjoyable stay for everyone.
			</p>
		</div>
	</section>

	<section class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20">
				{sections.map((section) => (
					<div class="border-t border-beach-sky/30 pt-12">
						<div class="flex items-center mb-8">
							<span class="w-10 h-10 bg-beach-sand/10 text-beach-sand flex items-center justify-center rounded-sm mr-4">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									{section.icon === 'home' && <><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></>}
									{section.icon === 'info' && <><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></>}
									{section.icon === 'trash' && <><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></>}
									{section.icon === 'truck' && <><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></>}
									{section.icon === 'heart' && <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>}
									{section.icon === 'droplet' && <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>}
									{section.icon === 'target' && <><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></>}
									{section.icon === 'sun' && <><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></>}
								</svg>
							</span>
							<h2 class="text-xl font-serif text-beach-slate uppercase tracking-wider">{section.title}</h2>
						</div>
						<ul class="space-y-4">
							{section.rules.map((rule) => (
								<li class="flex items-start text-sm text-beach-slate/70 font-sans leading-relaxed">
									<span class="text-beach-sand mr-3 mt-1.5 w-1.5 h-1.5 rounded-full bg-beach-sand shrink-0"></span>
									{rule}
								</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="py-24 bg-beach-sky/20">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h2 class="text-3xl font-serif text-beach-slate mb-8">Need a PDF Copy?</h2>
			<p class="text-beach-slate/70 font-sans text-sm mb-12 uppercase tracking-widest leading-loose">
				Download the official Rules & Regulations document to keep with your records.
			</p>
			<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-8">
				<a href="https://irp-cdn.multiscreensite.com/98c7d9ee/files/uploaded/BD%20Rules%20and%20Regulations%20Revised%2010-12-2020.pdf" target="_blank" class="inline-block bg-beach-slate text-white px-12 py-4 text-[10px] font-sans uppercase tracking-[.4em] hover:bg-beach-sand transition-all duration-300">
					Download Rules (PDF)
				</a>
				<a href="https://myfwc.com/news/all-news/scallop-821/" target="_blank" class="inline-block border border-beach-slate text-beach-slate px-12 py-4 text-[10px] font-sans uppercase tracking-[.4em] hover:bg-beach-slate hover:text-white transition-all duration-300">
					FWC Scallop Info
				</a>
			</div>
		</div>
	</section>
</Layout>
