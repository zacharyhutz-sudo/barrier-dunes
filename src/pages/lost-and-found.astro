---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lost & Found">
	<section class="py-20 bg-beach-sea/10">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<span class="text-beach-sand font-sans text-[10px] uppercase tracking-[.3em] mb-4 block">COMMUNITY REACH</span>
			<h1 class="text-5xl font-serif text-beach-slate mb-8">Lost & Found</h1>
			<p class="text-beach-slate/70 font-sans text-sm leading-relaxed tracking-wide">
				Reuniting pets and property with their owners using our community network. 
				A simple, one-stop source for exchanging lost and found information at Barrier Dunes.
			</p>
		</div>
	</section>

	<section class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-24">
			<!-- Current Listings -->
			<div>
				<h2 class="text-xs font-sans font-bold text-beach-sand uppercase tracking-[.4em] mb-12">Current Listings</h2>
				<div class="border border-beach-sky/20 p-16 text-center">
					<p class="text-beach-slate/40 italic font-serif text-lg">No active listings at this time.</p>
					<div class="w-12 h-[1px] bg-beach-sand mx-auto mt-8 opacity-30"></div>
				</div>
			</div>

			<!-- Request Form -->
			<div>
				<h2 class="text-xs font-sans font-bold text-beach-sand uppercase tracking-[.4em] mb-12">Submit a Request</h2>
				<form class="space-y-8 font-sans">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-beach-slate/60 mb-3">Your Name</label>
							<input type="text" class="w-full bg-beach-sky/5 border border-beach-sky/20 p-4 text-sm focus:border-beach-sea focus:outline-none transition-colors" />
						</div>
						<div>
							<label class="block text-[10px] uppercase tracking-widest text-beach-slate/60 mb-3">Email Address</label>
							<input type="email" class="w-full bg-beach-sky/5 border border-beach-sky/20 p-4 text-sm focus:border-beach-sea focus:outline-none transition-colors" />
						</div>
					</div>
					<div>
						<label class="block text-[10px] uppercase tracking-widest text-beach-slate/60 mb-3">I have...</label>
						<select class="w-full bg-beach-sky/5 border border-beach-sky/20 p-4 text-sm focus:border-beach-sea focus:outline-none transition-colors">
							<option>Lost an item</option>
							<option>Found an item</option>
						</select>
					</div>
					<div>
						<label class="block text-[10px] uppercase tracking-widest text-beach-slate/60 mb-3">Description</label>
						<textarea rows="5" class="w-full bg-beach-sky/5 border border-beach-sky/20 p-4 text-sm focus:border-beach-sea focus:outline-none transition-colors" placeholder="Please describe the item or pet, including location and date..."></textarea>
					</div>
					<button type="submit" class="bg-beach-slate text-white px-12 py-4 text-[10px] font-sans uppercase tracking-[.4em] hover:bg-beach-sea transition-all duration-300">
						Submit Request
					</button>
				</form>
			</div>
		</div>
	</section>
</Layout>
