---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lost & Found">
	<section class="py-16 md:py-20 bg-beach-sky/10">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<span class="text-beach-sand font-sans text-[10px] uppercase tracking-[.3em] mb-4 block">COMMUNITY ASSISTANCE</span>
			<h1 class="text-3xl sm:text-4xl md:text-5xl font-serif text-beach-slate mb-8">Lost & Found</h1>
			<p class="text-beach-slate/70 font-sans text-sm leading-relaxed tracking-wide">
				Reuniting pets and property with their owners. 
				A community effort to keep Barrier Dunes whole.
			</p>
		</div>
	</section>

	<section class="py-16 md:py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-16 md:gap-20">
			
			<!-- Information & Policy -->
			<div class="space-y-10 md:space-y-12">
				<div>
					<h2 class="text-2xl md:text-3xl font-serif text-beach-slate mb-6 md:mb-8 italic">Reuniting our Community</h2>
					<p class="text-beach-slate/70 font-sans text-sm leading-relaxed mb-6">
						The sole purpose of the Barrier Dunes' Lost and Found page is to reunite lost and found pets and property with their respective owners using our community reach.
					</p>
					<p class="text-beach-slate/70 font-sans text-sm leading-relaxed mb-6">
						Whether it's a family pet, a favorite pair of sunglasses, or beach gear left on the boardwalk, we are pleased to offer this convenient source for the exchange of information.
					</p>
				</div>

				<div class="p-6 md:p-8 bg-beach-sand/5 border border-beach-sand/20 rounded-sm">
					<h3 class="text-[10px] md:text-xs font-sans uppercase tracking-widest text-beach-sand mb-4">Current Notices</h3>
					<div class="flex items-center text-beach-slate/40 italic font-serif py-4 border-t border-beach-sand/10 text-sm">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mr-3 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
						No active lost or found items at the moment.
					</div>
				</div>
			</div>

			<!-- Report Form (Visualized) -->
			<div class="bg-beach-slate p-8 md:p-16 text-white rounded-sm shadow-2xl">
				<h2 class="text-2xl font-serif mb-6 uppercase tracking-widest text-beach-sea">Report an Item</h2>
				<p class="text-white/60 font-sans text-[10px] md:text-xs uppercase tracking-widest mb-10 leading-relaxed">
					Please fill out the details below to add a notice to our community board.
				</p>
				
				<form class="space-y-8">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						<div class="space-y-2">
							<label class="text-[10px] uppercase tracking-widest text-white/40">Full Name</label>
							<input type="text" class="w-full bg-white/5 border-b border-white/20 py-3 text-sm focus:border-beach-sea outline-none transition-colors rounded-none appearance-none" placeholder="John Doe" />
						</div>
						<div class="space-y-2">
							<label class="text-[10px] uppercase tracking-widest text-white/40">Phone Number</label>
							<input type="tel" class="w-full bg-white/5 border-b border-white/20 py-3 text-sm focus:border-beach-sea outline-none transition-colors rounded-none appearance-none" placeholder="(555) 000-0000" />
						</div>
					</div>
					<div class="space-y-2">
						<label class="text-[10px] uppercase tracking-widest text-white/40">Item Description</label>
						<textarea class="w-full bg-white/5 border-b border-white/20 py-3 text-sm focus:border-beach-sea outline-none transition-colors min-h-[100px] rounded-none appearance-none" placeholder="Detailed description of the item or pet..."></textarea>
					</div>
					<div class="space-y-2">
						<label class="text-[10px] uppercase tracking-widest text-white/40">Location Last Seen / Found</label>
						<input type="text" class="w-full bg-white/5 border-b border-white/20 py-3 text-sm focus:border-beach-sea outline-none transition-colors rounded-none appearance-none" placeholder="e.g., Boardwalk #3, Gulf Front Pool" />
					</div>
					
					<button type="submit" class="w-full bg-white text-beach-slate py-4 text-[10px] font-sans uppercase tracking-[.4em] hover:bg-beach-sea hover:text-white transition-all duration-300 mt-4 shadow-xl active:scale-[0.98]">
						Submit Notice
					</button>
				</form>
			</div>

		</div>
	</section>
</Layout>
