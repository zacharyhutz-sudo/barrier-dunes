---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resources">
	<section class="py-20 bg-beach-sky/20">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<span class="text-beach-sand font-sans text-[10px] uppercase tracking-[.3em] mb-4 block">COMMUNITY MANAGEMENT</span>
			<h1 class="text-5xl font-serif text-beach-slate mb-8">Barrier Dunes Resources</h1>
			<p class="text-beach-slate/70 font-sans text-sm leading-relaxed tracking-wide">
				Forms, documents, and essential information for renters and homeowners. 
				Manage your stay and access community amenities.
			</p>
		</div>
	</section>

	<section class="py-24 bg-white">
		<div class="max-w-5xl mx-auto px-4 space-y-24">
			
			<!-- Maintenance & Reporting -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
				<div>
					<h2 class="text-2xl font-serif text-beach-slate mb-6 uppercase tracking-wider">Renter Information</h2>
					<p class="text-beach-slate/70 font-sans text-sm leading-relaxed mb-8">
						If you are a renter at Barrier Dunes and need to report any issues concerning services, amenities, or missing items, 
						please contact your rental contact person as shown on your rental contract.
					</p>
					<div class="p-6 bg-beach-sky/10 border-l-2 border-beach-sea">
						<p class="text-xs font-sans text-beach-slate/60 uppercase tracking-widest italic">Note: The Association does not manage individual rentals directly.</p>
					</div>
				</div>
				<div class="bg-beach-sea/10 aspect-square flex items-center justify-center p-12">
					<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round" class="text-beach-sea/50"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
				</div>
			</div>

			<!-- Clubhouse Rental -->
			<div class="bg-beach-slate text-white p-12 md:p-20 grid grid-cols-1 md:grid-cols-3 gap-12">
				<div class="md:col-span-2">
					<h2 class="text-3xl font-serif mb-6 italic">Clubhouse Rental</h2>
					<p class="text-white/70 font-sans text-sm leading-relaxed mb-10 tracking-wide">
						The Barrier Dunes Clubhouse is available for private events, meetings, and community use. 
						Please ensure you read the entire rental agreement to avoid cancellations or extra charges.
					</p>
					<div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-8">
						<a href="https://irp-cdn.multiscreensite.com/98c7d9ee/files/uploaded/CLUBHOUSE%20RENTAL%20AGREEMENT%20August%202020.pdf" target="_blank" class="inline-block border border-white/30 px-8 py-3 text-[10px] font-sans uppercase tracking-[.3em] hover:bg-white hover:text-beach-slate transition-all duration-300 text-center">
							Download Agreement
						</a>
						<a href="https://irp-cdn.multiscreensite.com/98c7d9ee/files/uploaded/BD%20Rules%20and%20Regulations%20Revised%2010-12-2020.pdf" target="_blank" class="inline-block border border-white/30 px-8 py-3 text-[10px] font-sans uppercase tracking-[.3em] hover:bg-white hover:text-beach-slate transition-all duration-300 text-center">
							Rules & Regulations (PDF)
						</a>
					</div>
				</div>
				<div class="flex flex-col justify-center">
					<div class="bg-white/5 p-8 border border-white/10">
						<h3 class="text-xs font-sans uppercase tracking-widest text-beach-sea mb-4">Rental Form</h3>
						<p class="text-[10px] text-white/50 font-sans leading-relaxed mb-6">Reservation requests can be submitted via the homeowner portal.</p>
						<a href="https://app.condocontrol.com/login?brand=barrier" class="text-xs font-sans uppercase tracking-[.3em] border-b border-beach-sea pb-1 hover:text-beach-sea transition-colors">Access Portal</a>
					</div>
				</div>
			</div>

		</div>
	</section>
</Layout>
