---
const navLinks = [
	{ text: 'Home', href: '/barrier-dunes/' },
	{ text: 'Condos', href: '/barrier-dunes/condos' },
	{ text: 'Rules & Regulations', href: '/barrier-dunes/rules-and-regulations' },
	{ text: 'Local Attractions', href: '/barrier-dunes/local-attractions' },
	{ text: 'Local Resources', href: '/barrier-dunes/local-resources' },
	{ text: 'Lost & Found', href: '/barrier-dunes/lost-and-found' },
	{ text: 'Resources', href: '/barrier-dunes/barrier-dunes-resources' },
];
---

<header class="bg-white border-b border-beach-sky/30 sticky top-0 z-50">
	<nav class="mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
		<div class="flex-shrink-0">
			<a href="/barrier-dunes/" class="flex items-center group">
				<div class="h-12 w-12 bg-beach-sea flex items-center justify-center rounded-full mr-3 group-hover:bg-beach-sky transition-colors">
					<span class="text-white font-serif text-xl italic">BD</span>
				</div>
				<div>
					<span class="text-base sm:text-lg lg:text-xl font-serif text-beach-slate uppercase tracking-wider sm:tracking-widest leading-none block">Barrier Dunes</span>
					<p class="text-[8px] sm:text-[9px] lg:text-[10px] font-sans text-beach-sand uppercase tracking-widest sm:tracking-[.2em] mt-1 whitespace-nowrap">St. Joseph Peninsula</p>
				</div>
			</a>
		</div>

		<div class="hidden md:flex items-center space-x-4 lg:space-x-8">
			{navLinks.map((link) => (
				<a href={link.href} class="text-[11px] lg:text-sm font-sans text-beach-slate hover:text-beach-sea transition-colors uppercase tracking-wider whitespace-nowrap">
					{link.text}
				</a>
			))}
			<a href="https://app.condocontrol.com/login?brand=barrier" target="_blank" class="bg-beach-slate text-white px-4 lg:px-6 py-2 rounded-sm text-[11px] lg:text-sm font-sans uppercase tracking-widest hover:bg-beach-sea transition-colors whitespace-nowrap">
				Login
			</a>
		</div>

		<!-- Mobile Menu Button -->
		<div class="md:hidden">
			<button id="mobile-menu-button" class="text-beach-slate p-2" aria-label="Menu">
				<svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
				<svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
			</button>
		</div>
	</nav>

	<!-- Mobile Menu Sidebar -->
	<div id="mobile-menu" class="fixed inset-0 z-[100] transform translate-x-full transition-transform duration-500 ease-in-out md:hidden invisible overflow-hidden">
		<!-- Backdrop -->
		<div id="mobile-menu-backdrop" class="absolute inset-0 bg-beach-slate/60 backdrop-blur-md opacity-0 transition-opacity duration-500"></div>
		
		<!-- Sidebar -->
		<div class="absolute right-0 top-0 h-full w-[85%] max-w-sm bg-white shadow-[-20px_0_60px_-15px_rgba(0,0,0,0.3)] p-8 overflow-y-auto flex flex-col justify-between">
			<div class="flex flex-col space-y-2 mt-12">
				{navLinks.map((link, i) => (
					<a 
						href={link.href} 
						class="mobile-nav-link opacity-0 translate-x-12 transition-all duration-500 text-lg font-serif text-beach-slate hover:text-beach-sand uppercase tracking-[.1em] border-b border-beach-sky/10 py-3 flex items-center justify-between"
						style={`transition-delay: ${100 + i * 40}ms`}
					>
						{link.text}
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-beach-sand/40"><path d="m9 18 6-6-6-6"/></svg>
					</a>
				))}
				<a 
					href="https://app.condocontrol.com/login?brand=barrier" 
					target="_blank" 
					class="mobile-nav-link opacity-0 translate-x-12 transition-all duration-500 bg-beach-slate text-white px-8 py-4 rounded-sm text-xs font-sans uppercase tracking-[.25em] text-center hover:bg-beach-sea transition-colors shadow-lg mt-6"
					style={`transition-delay: ${100 + navLinks.length * 40}ms`}
				>
					HOA Login
				</a>
			</div>

			<div class="mt-8 pb-4 opacity-40 text-center">
				<p class="text-[8px] font-sans text-beach-sand uppercase tracking-[.4em] leading-relaxed">Established on the St. Joseph Peninsula</p>
			</div>
		</div>
	</div>
</header>

<script>
	const menuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');
	const backdrop = document.getElementById('mobile-menu-backdrop');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');
	const navLinks = document.querySelectorAll('.mobile-nav-link');

	function toggleMenu() {
		const isOpen = mobileMenu?.classList.contains('translate-x-0');
		
		if (isOpen) {
			// Closing
			mobileMenu?.classList.add('translate-x-full');
			mobileMenu?.classList.remove('translate-x-0');
			backdrop?.classList.add('opacity-0');
			backdrop?.classList.remove('opacity-100');
			
			navLinks.forEach(link => {
				link.classList.add('opacity-0', 'translate-x-12');
				link.classList.remove('opacity-100', 'translate-x-0');
			});

			setTimeout(() => {
				mobileMenu?.classList.add('invisible');
			}, 500);

			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
			document.body.style.overflow = 'auto';
		} else {
			// Opening
			mobileMenu?.classList.remove('invisible');
			mobileMenu?.classList.remove('translate-x-full');
			mobileMenu?.classList.add('translate-x-0');
			backdrop?.classList.remove('opacity-0');
			backdrop?.classList.add('opacity-100');
			
			navLinks.forEach(link => {
				link.classList.remove('opacity-0', 'translate-x-12');
				link.classList.add('opacity-100', 'translate-x-0');
			});

			menuIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
			document.body.style.overflow = 'hidden';
		}
	}

	menuButton?.addEventListener('click', toggleMenu);
	backdrop?.addEventListener('click', toggleMenu);

	// Close menu on link click
	navLinks.forEach(link => {
		link.addEventListener('click', () => {
			toggleMenu();
		});
	});
</script>
