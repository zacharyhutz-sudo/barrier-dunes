---
import Layout from '../layouts/Layout.astro';

const condos = [
	{
		id: "sherri",
		name: "There's Always Time for the Sea",
		image: "/barrier-dunes/images/sherri-condo.jpg",
		beds: "2 Bedrooms (1 King, 2 Queens)",
		baths: "2 Bathrooms",
		features: [
			"Steps from the beach boardwalk",
			"Fully stocked gourmet kitchen",
			"Private balconies for each bedroom",
			"Located near tennis courts and pool"
		],
		link: "https://theresalwaystimeforthesea.com",
		coordinates: [29.74901, -85.39838]
	},
	{
		id: "dune-reel-good",
		name: "Dune Reel Good",
		image: "/barrier-dunes/images/dune-reel-good.jpg",
		beds: "2 Bedrooms (King, Queen)",
		baths: "2 Bathrooms",
		features: [
			"Tesla Charger in Carport",
			"200 steps to the sand",
			"Two large Gulf Side Decks",
			"Beach gear included with stay",
			"Enclosed Hot/Cold Outdoor Shower"
		],
		link: "https://www.thecapeescape.com/cape-san-blas-vacation-rentals/dune-reel-good/",
		coordinates: [29.74788, -85.39801]
	}
];
---

<Layout title="Condos for Rent">
	<!-- Title Section -->
	<section class="py-20 bg-beach-sand/5">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<span class="text-beach-sand font-sans text-[10px] uppercase tracking-[.3em] mb-4 block">STAY AT BARRIER DUNES</span>
			<h1 class="text-5xl font-serif text-beach-slate mb-8">Community Map</h1>
			<p class="text-beach-slate/70 font-sans text-sm leading-relaxed tracking-wide">
				Find your home away from home. Use the interactive map below to explore our rentals and amenities.
			</p>
		</div>
	</section>

	<!-- Map Section -->
	<section class="relative h-[450px] md:h-[600px] w-full bg-beach-slate overflow-hidden border-y border-beach-sky/20">
		<div id="condo-map" class="h-full w-full z-10"></div>
		
		<!-- Mobile Interaction Overlay -->
		<div id="map-interaction-overlay" class="absolute inset-0 z-[15] bg-beach-slate/10 flex items-center justify-center cursor-pointer group md:hidden">
			<div class="bg-white/90 backdrop-blur-sm px-6 py-3 border border-beach-sky/20 shadow-xl pointer-events-none">
				<p class="text-[10px] font-sans uppercase tracking-[.3em] text-beach-slate">Tap to Explore Map</p>
			</div>
		</div>

		<!-- Map Legend -->
		<div class="absolute bottom-6 right-6 z-20 hidden md:block">
			<div class="bg-white/90 backdrop-blur-sm p-4 border border-beach-sky/20 shadow-lg space-y-2">
				<div class="flex items-center text-[10px] font-sans uppercase tracking-widest text-beach-slate">
					<span class="w-3 h-3 bg-beach-sea rounded-full mr-3 shadow-sm"></span> Available Condos
				</div>
				<div class="flex items-center text-[10px] font-sans uppercase tracking-widest text-beach-slate">
					<span class="w-3 h-3 bg-beach-sand rounded-full mr-3 shadow-sm"></span> Amenities
				</div>
			</div>
		</div>
	</section>

	<section class="py-24 bg-white">
		<div class="max-w-6xl mx-auto px-4">
			<div class="space-y-16">
				{condos.map((condo) => (
					<div id={condo.id} class="flex flex-col md:flex-row bg-white border border-beach-sky/20 overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-500">
						<!-- Image Left -->
						<div class="w-full md:w-1/2 aspect-video md:aspect-auto h-64 md:h-auto overflow-hidden">
							<img src={condo.image} alt={condo.name} class="w-full h-full object-cover" />
						</div>
						
						<!-- Content Right -->
						<div class="w-full md:w-1/2 p-10 md:p-16 flex flex-col justify-center">
							<h2 class="text-2xl font-serif text-beach-slate mb-6 uppercase tracking-widest leading-tight">{condo.name}</h2>
							
							<div class="flex items-center space-x-6 mb-8 text-[10px] font-sans text-beach-sand uppercase tracking-widest font-bold">
								<span class="flex items-center">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/><path d="M12 4v16"/><path d="M2 17h20"/></svg>
									{condo.beds}
								</span>
								<span class="flex items-center">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-2.12 0 1.5 1.5 0 0 0 0 2.12L7 8.5"/><rect x="2" y="14" width="20" height="8" rx="2"/><path d="M5 14v-2a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v2"/></svg>
									{condo.baths}
								</span>
							</div>

							<ul class="space-y-3 mb-12">
								{condo.features.map((feature) => (
									<li class="flex items-center text-sm text-beach-slate/70 font-sans">
										<span class="w-1.5 h-1.5 rounded-full bg-beach-sea mr-3"></span>
										{feature}
									</li>
								))}
							</ul>

							<a href={condo.link} target="_blank" class="inline-block bg-beach-slate text-white px-10 py-4 text-[10px] font-sans uppercase tracking-[.4em] text-center hover:bg-beach-sea transition-all duration-300">
								View Availability
							</a>
						</div>
					</div>
				))}
			</div>

			<!-- Renter Notice -->
			<div class="mt-24 p-12 bg-beach-sky/10 border border-beach-sky/20 text-center">
				<h3 class="text-xl font-serif text-beach-slate mb-4">Want to list your condo?</h3>
				<p class="text-beach-slate/60 font-sans text-xs uppercase tracking-widest leading-loose mb-8 max-w-xl mx-auto">
					This page is a directory of private rentals at Barrier Dunes. Owners can contact the association to have their listing included.
				</p>
				<a href="/barrier-dunes/barrier-dunes-resources" class="inline-block border border-beach-slate text-beach-slate px-8 py-3 text-[10px] font-sans uppercase tracking-[.4em] hover:bg-beach-slate hover:text-white transition-all duration-300">
					Contact Association
				</a>
			</div>
		</div>
	</section>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script is:inline define:vars={{ condos }}>
	// Wait for Leaflet to be ready
	window.addEventListener('load', () => {
		const isMobile = window.innerWidth < 768;
		
		const map = L.map('condo-map', {
			center: [29.7485, -85.3975],
			zoom: 17,
			scrollWheelZoom: false,
			dragging: !isMobile,
			tap: !isMobile
		});

		// Add ESRI Satellite Imagery with a custom class for filtering
		L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
			attribution: 'Tiles &copy; Esri &mdash; Source: Esri, i-cubed, USDA, USGS, AEX, GeoEye, Getmapping, Aerogrid, IGN, IGP, UPR-EGP, and the GIS User Community',
			className: 'beachy-map-tiles'
		}).addTo(map);

		// Handle Mobile Interaction Overlay
		const overlay = document.getElementById('map-interaction-overlay');
		if (overlay) {
			overlay.addEventListener('click', () => {
				overlay.style.display = 'none';
				map.dragging.enable();
				if (map.tap) map.tap.enable();
			});
		}

		// Custom Condo Icon
		const condoIcon = L.divIcon({
			className: 'custom-div-icon',
			html: `<div style="background-color: #008080; width: 14px; height: 14px; border: 2.5px solid #ffffff; border-radius: 50%; box-shadow: 0 2px 8px rgba(0,0,0,0.5), 0 0 0 2px rgba(0,128,128,0.2);"></div>`,
			iconSize: [14, 14],
			iconAnchor: [7, 7]
		});

		// Add markers for each condo
		condos.forEach(condo => {
			if (condo.coordinates) {
				const marker = L.marker(condo.coordinates, { icon: condoIcon }).addTo(map);
				marker.bindPopup(`
					<div style="font-family: serif; text-align: center; padding: 5px;">
						<p style="margin: 0 0 8px 0; text-transform: uppercase; letter-spacing: 1px; font-size: 11px; font-weight: bold; color: #333;">${condo.name}</p>
						<a href="#${condo.id}" style="color: #008080; text-decoration: none; font-size: 10px; text-transform: uppercase; font-weight: bold;">View Details</a>
					</div>
				`);
			}
		});

		// Add Amenities markers
		const amenityIcon = L.divIcon({
			className: 'custom-div-icon',
			html: `<div style="background-color: #ff9f43; width: 10px; height: 10px; border: 2px solid white; border-radius: 50%; box-shadow: 0 2px 6px rgba(0,0,0,0.4);"></div>`,
			iconSize: [10, 10],
			iconAnchor: [5, 5]
		});

		const amenities = [
			{ name: "Gated Entrance", coords: [29.74821, -85.39611] },
			{ name: "Beachfront Pool", coords: [29.74852, -85.39932] },
			{ name: "Interior Pool", coords: [29.74931, -85.39780] },
			{ name: "Tennis Courts", coords: [29.74927, -85.39813] },
			{ name: "Playground", coords: [29.74882, -85.39650] }
		];

		amenities.forEach(amenity => {
			L.marker(amenity.coords, { icon: amenityIcon }).addTo(map)
				.bindTooltip(amenity.name, { permanent: false, direction: 'top' });
		});
	});
</script>

<style is:global>
	/* Balanced Aerial Color Grade */
	.beachy-map-tiles {
		/* 
		   Brightness 1.1: Clean, airy feel
		   Saturate 0.85: Restores natural greens to the vegetation
		   Contrast 1.05: Sharp but natural
		   Hue-rotate -10deg: Neutralizes the heaviest yellows without killing the green channel
		*/
		filter: brightness(1.1) saturate(0.85) contrast(1.05) hue-rotate(-10deg) !important;
	}

	.leaflet-popup-content-wrapper {
		border-radius: 0;
		padding: 5px;
	}
	.leaflet-popup-tip {
		display: none;
	}
	.leaflet-container {
		font-family: inherit;
	}
</style>
